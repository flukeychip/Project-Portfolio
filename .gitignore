# Raw video source files — converted .mp4 versions are used instead
*.mov
*.MOV

# Local staging area for new project folders (not committed)
staging/

# Local agent/project context file (never committed)
CONTEXT.md

# Ignore all root-level folders by default (local project drops),
# then allow only folders that belong in the published site.
/*/
!/assets/
!/css/
!/js/
!/lib/
!/public/
!/scripts/
